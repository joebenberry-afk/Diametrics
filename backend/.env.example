# DiaMetrics Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Gemini API key (Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key_here

# USDA FoodData Central API key
# Free registration: https://fdc.nal.usda.gov/api-guide.html
# Leave as DEMO_KEY for development (30 req/hr limit)
USDA_API_KEY=DEMO_KEY

# Shared secret between the Flutter app and this backend.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
BACKEND_API_KEY=generate_a_strong_random_secret_here
