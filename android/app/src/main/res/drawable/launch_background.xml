<?xml version="1.0" encoding="utf-8"?>
<!-- DiaMetrics launch splash — brand dark background with centered mascot -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Brand dark background (#0D1B2A) -->
    <item android:drawable="@color/brand_dark" />

    <!-- Centered launcher icon -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launcher_icon" />
    </item>
</layer-list>
